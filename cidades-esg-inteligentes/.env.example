# ==================================================
# Cidades ESG Inteligentes - Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env no repositório!
# ==================================================

# Aplicação
NODE_ENV=development
APP_VERSION=1.0.0
PORT=3000

# Banco de Dados PostgreSQL
POSTGRES_USER=esguser
POSTGRES_PASSWORD=TROQUE_ESTA_SENHA_EM_PRODUCAO
POSTGRES_DB=esgdb
POSTGRES_PORT=5432

# Cache Redis
REDIS_PASSWORD=TROQUE_ESTA_SENHA_EM_PRODUCAO
REDIS_PORT=6379

# Segurança
JWT_SECRET=TROQUE_ESTE_SECRET_EM_PRODUCAO_USE_32_CHARS_MINIMO

# Nginx
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Docker Registry (para CI/CD)
DOCKER_REGISTRY=ghcr.io

# Grafana
GRAFANA_PASSWORD=admin123
